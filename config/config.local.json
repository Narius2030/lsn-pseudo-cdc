{
  "sqlserver": {
    "connection_string": "DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=sakila;UID=sa;PWD=dev!12345;Encrypt=yes;TrustServerCertificate=yes;ApplicationIntent=ReadOnly",
    "login_timeout_seconds": 15,
    "query_timeout_seconds": 120,
    "fetch_size": 500,
    "lsn_window_size": 1000,
    "lock_timeout_ms": 3000
  },
  "s3": {
    "bucket": "datalake-raw",
    "data_prefix": "comc-sakila-cdc/sakila2021",
    "region_name": "us-east-1",
    "endpoint_url": "http://localhost:9000",
    "profile_name": null,
    "access_key_id": "minioadmin",
    "secret_access_key": "minioadmin",
    "session_token": null,
    "server_side_encryption": null,
    "ssekms_key_id": null
  },
  "state_store": {
    "type": "s3",
    "bucket": "datalake-raw",
    "key": "comc-sakila-cdc/sakila2021/database=sakila2021/state/bookmarks.json"
  },
  "runtime": {
    "server_name": "SAKILA_MASTER",
    "topic_prefix": "SAKILA_MASTER",
    "source_timezone": "UTC",
    "local_work_dir": "/tmp/sqlserver-cdc-s3",
    "output_mode": "s3",
    "local_output_dir": "./local-output",
    "enable_compression": false,
    "partition_by_date": true,
    "snapshot_mode": "initial",
    "commit_bookmarks": true,
    "validate_destination_on_startup": true,
    "enforce_sqlserver_2014_sp1": false,
    "allow_best_effort_without_command_id": true,
    "inspect_cdc_health": true,
    "fail_on_cdc_engine_errors": true,
    "emit_tombstone_on_delete": false,
    "include_schemas": true,
    "cleanup_failed_runs": true,
    "fail_on_lsn_gap": true,
    "fail_on_incomplete_update_pair": true,
    "min_lsn_window_size": 100,
    "window_size_reduction_factor": 2,
    "max_retries": 3,
    "retry_backoff_seconds": 2.0,
    "retry_max_delay_seconds": 30.0
  },
  "logging": {
    "level": "INFO",
    "file_path": "./logs/sqlserver-cdc-s3.log"
  }
}
